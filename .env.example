# mode: paper or live
BOT_MODE=paper
LIVE_TRADING_ACK=

# venue: drift_gateway (true long/short), solana_jupiter, or binance
TRADING_VENUE=solana_jupiter
SOL_ONLY_MODE=1
ALLOW_PAPER_SHORTS=1
APP_NAME=AIG Trader OS
LOG_DIR=logs

# base config
BUDGET_USD=50
SCAN_INTERVAL=20
RISK_PER_TRADE=0.15
MAX_POSITIONS=4
STOP_LOSS_PCT=0.025
TAKE_PROFIT_PCT=0.045
MAX_POSITION_AGE_MINUTES=240
MAX_DAILY_DRAWDOWN_PCT=0.08
COOLDOWN_MINUTES=20
BUY_THRESHOLD=0.008
SELL_THRESHOLD=-0.006
TOP_N_MARKETS=25
CANDIDATES_PER_CYCLE=6
MIN_QUOTE_VOLUME_USD=500000

# paper execution realism
PAPER_FEE_BPS=10
PAPER_SLIPPAGE_BPS=5

# agent brain (OpenClaw-style decision layer)
BRAIN_ENABLED=1
BRAIN_PROVIDER=local
BRAIN_MODEL=qwen2.5:7b-instruct
BRAIN_TEMPERATURE=0.2
BRAIN_MAX_MEMORY_ITEMS=25
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# solana + jupiter live settings
