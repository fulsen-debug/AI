# scanner cadence
SCAN_INTERVAL=20

# portfolio and risk controls
RISK_PER_TRADE=0.15
MAX_POSITIONS=4
STOP_LOSS_PCT=0.025
TAKE_PROFIT_PCT=0.045
MAX_POSITION_AGE_MINUTES=240
MAX_DAILY_DRAWDOWN_PCT=0.08
COOLDOWN_MINUTES=20

# signal thresholds
BUY_THRESHOLD=0.008
SELL_THRESHOLD=-0.006

# dynamic universe
QUOTE_ASSET=USDT
TOP_N_MARKETS=25
CANDIDATES_PER_CYCLE=6
MIN_QUOTE_VOLUME_USD=5000000

# paper fill realism (kept in parity with live accounting format)
