SOLANA_TOKEN_MINTS=So11111111111111111111111111111111111111112,JUPyiwrYJFskUPiHa7hkeR8VUtAeFoSYbKedZNsDvCN,DezXAZ8z7PnrnRJjz3wXBoRgixCa6uX8L6FZt8f9J6s
JUPITER_SLIPPAGE_BPS=50

# binance live settings (optional fallback venue)
